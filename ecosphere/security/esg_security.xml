<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_ecosphere" model="ir.module.category">
        <field name="name">EcoSphere ESG</field>
        <field name="description">EcoSphere ESG platform access groups.</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_esg_employee" model="res.groups">
        <field name="name">ESG Employee</field>
        <field name="category_id" ref="module_category_ecosphere"/>
    </record>

    <record id="group_esg_manager" model="res.groups">
        <field name="name">ESG Manager</field>
        <field name="category_id" ref="module_category_ecosphere"/>
        <field name="implied_ids" eval="[(4, ref('group_esg_employee'))]"/>
    </record>

    <record id="group_esg_auditor" model="res.groups">
        <field name="name">ESG Auditor</field>
        <field name="category_id" ref="module_category_ecosphere"/>
    </record>

    <record id="group_esg_admin" model="res.groups">
        <field name="name">ESG Admin</field>
        <field name="category_id" ref="module_category_ecosphere"/>
        <field name="implied_ids" eval="[
            (4, ref('group_esg_manager')),
            (4, ref('group_esg_auditor'))
        ]"/>
    </record>

    <record id="rule_esg_department_visible_to_esg_users" model="ir.rule">
        <field name="name">ESG departments visible to ESG users</field>
        <field name="model_id" ref="model_esg_department"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[
            (4, ref('group_esg_employee')),
            (4, ref('group_esg_manager')),
            (4, ref('group_esg_auditor')),
            (4, ref('group_esg_admin'))
        ]"/>
    </record>

    <record id="rule_esg_category_visible_to_esg_users" model="ir.rule">
        <field name="name">ESG categories visible to ESG users</field>
        <field name="model_id" ref="model_esg_category"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[
            (4, ref('group_esg_employee')),
            (4, ref('group_esg_manager')),
            (4, ref('group_esg_auditor')),
            (4, ref('group_esg_admin'))
        ]"/>
    </record>
</odoo>

