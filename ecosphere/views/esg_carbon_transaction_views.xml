<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_carbon_transaction_list" model="ir.ui.view">
        <field name="name">esg.carbon.transaction.list</field>
        <field name="model">esg.carbon.transaction</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="source_document"/>
                <field name="department_id"/>
                <field name="factor_id"/>
                <field name="quantity"/>
                <field name="uom"/>
                <field name="co2e" string="CO2e (kg)"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_esg_carbon_transaction_form" model="ir.ui.view">
        <field name="name">esg.carbon.transaction.form</field>
        <field name="model">esg.carbon.transaction</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" type="object" string="Confirm" class="btn-primary"
                            invisible="status == 'calculated'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="date"/>
                        <field name="source_document"/>
                    </group>
                    <group>
                        <field name="department_id"/>
                        <field name="factor_id"/>
                        <field name="quantity"/>
                        <field name="uom" readonly="1"/>
                        <field name="co2e" readonly="1"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_esg_carbon_transaction" model="ir.actions.act_window">
        <field name="name">Carbon Transactions</field>
        <field name="res_model">esg.carbon.transaction</field>
        <field name="view_mode">kanban,graph,list,form</field>
    </record>
</odoo>
