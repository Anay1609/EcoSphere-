<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_department_list" model="ir.ui.view">
        <field name="name">esg.department.list</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <list string="Departments">
                <field name="name"/>
                <field name="code"/>
                <field name="head_id"/>
                <field name="parent_id"/>
                <field name="employee_count"/>
                <field name="status" widget="badge" decoration-success="status == 'active'" decoration-muted="status == 'archived'"/>
            </list>
        </field>
    </record>

    <record id="view_esg_department_form" model="ir.ui.view">
        <field name="name">esg.department.form</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <form string="Department">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_activate" type="object" class="oe_stat_button" icon="fa-check" invisible="status == 'active'">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Activate</span>
                            </div>
                        </button>
                        <button name="action_archive" type="object" class="oe_stat_button" icon="fa-archive" invisible="status == 'archived'">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Archive</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="status"/>
                        </group>
                        <group>
                            <field name="head_id"/>
                            <field name="parent_id"/>
                            <field name="employee_count" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Employees">
                            <field name="employee_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="work_email"/>
                                    <field name="job_title"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_esg_department_search" model="ir.ui.view">
        <field name="name">esg.department.search</field>
        <field name="model">esg.department</field>
        <field name="arch" type="xml">
            <search string="Departments">
                <field name="name"/>
                <field name="code"/>
                <field name="head_id"/>
                <filter string="Active" name="active_departments" domain="[('status', '=', 'active')]"/>
                <filter string="Archived" name="archived_departments" domain="[('status', '=', 'archived')]"/>
                <group expand="0" string="Group By">
                    <filter string="Parent Department" name="group_parent" context="{'group_by': 'parent_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_esg_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">esg.department</field>
        <field name="view_mode">dashboard,kanban,list,form</field>
        <field name="search_view_id" ref="view_esg_department_search"/>
        <field name="context">{'search_default_active_departments': 1}</field>
    </record>
</odoo>

