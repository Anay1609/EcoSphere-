<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_esg_category_list" model="ir.ui.view">
        <field name="name">esg.category.list</field>
        <field name="model">esg.category</field>
        <field name="arch" type="xml">
            <list string="Categories">
                <field name="name"/>
                <field name="type"/>
                <field name="status" widget="badge" decoration-success="status == 'active'" decoration-muted="status == 'archived'"/>
            </list>
        </field>
    </record>

    <record id="view_esg_category_form" model="ir.ui.view">
        <field name="name">esg.category.form</field>
        <field name="model">esg.category</field>
        <field name="arch" type="xml">
            <form string="Category">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_activate" type="object" class="oe_stat_button" icon="fa-check" invisible="status == 'active'">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Activate</span>
                            </div>
                        </button>
                        <button name="action_archive" type="object" class="oe_stat_button" icon="fa-archive" invisible="status == 'archived'">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Archive</span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="type"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_esg_category_search" model="ir.ui.view">
        <field name="name">esg.category.search</field>
        <field name="model">esg.category</field>
        <field name="arch" type="xml">
            <search string="Categories">
                <field name="name"/>
                <filter string="CSR Activity" name="csr_activity" domain="[('type', '=', 'csr_activity')]"/>
                <filter string="Challenge" name="challenge" domain="[('type', '=', 'challenge')]"/>
                <filter string="Active" name="active_categories" domain="[('status', '=', 'active')]"/>
                <filter string="Archived" name="archived_categories" domain="[('status', '=', 'archived')]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_type" context="{'group_by': 'type'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_esg_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">esg.category</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_esg_category_search"/>
        <field name="context">{'search_default_active_categories': 1}</field>
    </record>
</odoo>

